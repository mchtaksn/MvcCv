@model MvcDB.Models.Tblegitim
@{
    ViewData["Title"] = "egitimekle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<br />
<h4>Yeni Eğitim Ekleme Sayfası</h4>
<br />
<form method="post">
    @Html.Label("Başlık")
    @Html.TextBoxFor(x => x.Baslik, new { @class = "form-control" })
    
    <br />
    @Html.Label("Alt Başlık1")
    @Html.TextBoxFor(x => x.Altbaslik1, new { @class = "form-control" })
    <br />
    @Html.Label("Alt Başlık2")
    @Html.TextBoxFor(x => x.Altbaslik2, new { @class = "form-control" })
    <br />
    @Html.Label("Tarih")
    @Html.TextBoxFor(x => x.Tarih, new { @class = "form-control" })
    <br />
    @Html.Label("GNO")
    @Html.TextBoxFor(x => x.Gno, new { @class = "form-control" })
    <br />
    <button class="btn btn-info">Eğitim Ekle</button>

</form>

