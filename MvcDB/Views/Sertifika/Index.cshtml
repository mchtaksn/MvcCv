@using MvcDB.Models
@model List<Tblsertifikalarim>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<!DOCTYPE html>
<html>
<body class="hold-transition sidebar-mini">   
            <section class="content">
                <div class="container-fluid">
                    <div class="row">
                        </div>
                        <div class="col-md-12">
                            <div class="card">
                                <div class="card-header p-2">
                                   
                                </div>
                                <div class="card-body">
                                        <div class="tab-pane" id="timeline">
                                            <!-- The timeline -->
                                            <div class="timeline timeline-inverse">
                                                <!-- timeline time label -->
                                @foreach (var serti in Model)
                                {
                                    <div class="time-label">
                                        <a href="/Sertifika/sertifikagetir/@serti.Id" class="btn btn-success">
                                        <span class="bg-success">
                                            10 Feb. 2014
                                        </span>
                                        </a>
                                    </div>
                                    <div>
                                     @*    <i class="fas fa-comment bg-primary"></i> *@
                                        <div class="timeline-item">
                                            <div class="timeline-body">
                                                @serti.Aciklama
                                            </div>
                                           @*  <div class="timeline-footer">
                                                <a href="#" class="btn btn-primary btn-sm">Düzenle</a>
                                                <a href="#" class="btn btn-danger btn-sm">Sil</a>
                                            </div> *@
                                        </div>
                                    </div>
                                }
                            </div>
                            <a href="/Sertifika/yenisertifika" class="btn btn-info">Yeni Sertifika Ekle</a>
                                        </div>
                                      
                                    </div>
                                </div>
                            </div>
                        </div>       
            </section>
</body>
</html>
