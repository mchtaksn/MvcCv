@model MvcDB.Models.Tblyeteneklerim
@{
    ViewData["Title"] = "yetenekguncelle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<br />
<h4>Yetenek Güncelleme Sayfası</h4>
<br />
<form method="post">
    @Html.Label("Yetenek")
    @Html.TextBoxFor(x => x.Yetenek, new { @class = "form-control" })

    @Html.Label("Oranı")"
    @Html.TextBoxFor(x => x.Oran, new { @class = "form-control" })
    

    <button class="btn btn-success">Güncelle</button>

</form>