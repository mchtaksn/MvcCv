
@{
    ViewData["Title"] = "deneyimekle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<br />
<h4>Yeni Deneyim Ekleme Sayfası</h4>
<br />
<form method="post">
    <label>Başlık</label>
    <br />
    <input type="text" name="Baslik" class="form-control" placeholder="Başlığı Yazınız" />
    <br />
    <input type="text" name="AltBaslik" class="form-control" placeholder="Alt Başlık" />
    <br />
    <input type="text" name="Tarih" class="form-control" placeholder="Çalışma Tarihi" />
    <br />
    <textarea placeholder="Açıklamanızı Giriniz" name="Aciklama" class="form-control"rows="5"></textarea>
    <br />
    <button class="btn btn-info">KAYDET</button>
</form>

