@using MvcDB.Models
@model List<Tblyeteneklerim>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
@{
    string renk = "";
}
@{
    string labelrenk = "";
}
<!DOCTYPE html>
<html>
<body class="hold-transition sidebar-mini">
    <div class="wrapper">
            <!-- Main content -->
            <section class="content">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="card">
                                <div class="card-header">
                                    <h3 class="card-title">Yetenek Listem</h3>
                                </div>
                                <!-- /.card-header -->
                                <div class="card-body">
                                    <a href="/Yetenek/yetenekekle/"class="btn btn-info">Yeni Yetenek Ekle</a>
                                    <br />
                                    <br />
                                    <table class="table table-bordered">
                                        <thead>
                                            <tr>
                                                <th style="width: 10px">#</th>
                                                <th>Yetenek</th>  
                                                <th>Derece</th>  
                                                 <th style="width:40px">Oran</th>
                                                <th>Düzenle</th>
                                                <th>Sil</th>
                                                
                                            </tr>
                                        </thead>
                                        <tbody>
                                        @foreach (var yet in Model)
                                        {
                                            if(yet.Oran>=0 && yet.Oran <= 50)
                                            {
                                                renk = "progress-bar bg-danger";
                                                labelrenk = "badge bg-danger";
                                            }
                                            if (yet.Oran >= 51 && yet.Oran <= 70)
                                            {
                                                renk = "progress-bar bg-warning";
                                                labelrenk = "badge bg-warning";
                                            }
                                            if (yet.Oran >= 71 && yet.Oran <= 84)
                                            {
                                                renk = "progress-bar bg-primary";
                                                labelrenk = "badge bg-primary";
                                            }
                                            if (yet.Oran >= 85 && yet.Oran <= 100)
                                            {
                                                renk = "progress-bar bg-success";
                                                labelrenk = "badge bg-success";
                                            }
                                            


                                            <tr>
                                                <td>@yet.Id</td>
                                                <td>@yet.Yetenek</td>
                                               
                                               
                                                <td>
                                                    <div class="progress progress-xs">
                                                        <div class="@renk" style="width:@yet.Oran%"></div>
                                                    </div>
                                                </td>
                                                <td><span class="@labelrenk">@yet.Oran</span></td>
                                                <td>
                                                    <a class="btn btn-info btn-sm" href="/Yetenek/yetenekguncelle/@yet.Id">
                                                        <i class="fas fa-pencil-alt">
                                                        </i>
                                                        Düzenle
                                                    </a>
                                                </td>
                                                <td>
                                                    <a class="btn btn-danger btn-sm" href="/Yetenek/yeteneksil/@yet.Id">
                                                        <i class="fas fa-trash">
                                                        </i>
                                                        Sil
                                                    </a>
                                                </td>
                                            </tr>
                                        }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div><!-- /.container-fluid -->
            </section>
            <!-- /.content -->
        </div>
</body>
</html>