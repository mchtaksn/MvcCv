@model MvcDB.Models.Tblsosyalmedya
@{
    ViewData["Title"] = "guncelle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<br />
<h4>Sosyal Medya Düzenleme Sayfası</h4>
<br />
<form method="post">
    @Html.Label("Sosyal Medya Adı")
    @Html.TextBoxFor(x => x.Ad,new { @class = "form-control" })
    <br />
    @Html.Label("Sosyal Medya Linki")
    @Html.TextBoxFor(x => x.Link, new { @class = "form-control" })
    <br />
    @Html.Label("Icon Bilgisi")
    @Html.TextBoxFor(x => x.Ikon, new { @class = "form-control" })
    <br />
    <button class="btn btn-success">Güncelle</button>

</form>
